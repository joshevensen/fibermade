# PostgreSQL connection URL (required).
# Local example: create a database named "shopify" and point this at it.
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/shopify"

# Encryption key for tokens at rest (Session.accessToken/refreshToken, FibermadeConnection.fibermadeApiToken).
# Generate with: npx cloak generate (from prisma-field-encryption).
PRISMA_FIELD_ENCRYPTION_KEY="k1.aesgcm256.YOUR_KEY_HERE"

# Fibermade platform API base URL (required for Connect and sync).
# Local: https://platform.test (or your Herd URL). Production: your platform API URL.
FIBERMADE_API_URL="https://fibermade.test"

# Fibermade platform URL shown to users (login link, etc.).
# Can be the same as FIBERMADE_API_URL or a separate frontend URL.
FIBERMADE_URL="https://fibermade.test"

# Shopify-related env (app URL, API key, etc.) is set by Shopify CLI when you run
# `shopify app dev`, or by your deployment platform. Do not commit .env with secrets.
