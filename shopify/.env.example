NODE_ENV=production
PORT=3000

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=file:./dev.sqlite

# ── Encryption ─────────────────────────────────────────────────────────────────
# Generate with: npx cloak generate
# WARNING: Must be identical on all web servers. Changing this will break decryption of existing records.
PRISMA_FIELD_ENCRYPTION_KEY=

# ── Shopify ────────────────────────────────────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,write_products,read_inventory,write_inventory,read_locations
SHOPIFY_APP_URL=https://shopify.fibermade.app

# ── Fibermade Platform ─────────────────────────────────────────────────────────
FIBERMADE_API_URL=https://fibermade.app
FIBERMADE_URL=https://fibermade.app

# ── Sentry ─────────────────────────────────────────────────────────────────────
# Create a project at sentry.io and paste the DSN here. Leave blank to disable.
SENTRY_DSN=
